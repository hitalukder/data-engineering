# Copy to .env and fill in. The deploy script auto-loads .env.

# ---- OpenShift target ----
NAMESPACE=milvus

# ---- Milvus version (helm chart) ----
# Leave empty for the chart's latest. Pin for reproducibility, e.g. 4.2.21
MILVUS_CHART_VERSION=

# ---- IBM Cloud Object Storage (S3-compatible) ----
# Regional public endpoint, e.g.:
#   us-south:  s3.us-south.cloud-object-storage.appdomain.cloud
#   eu-de:     s3.eu-de.cloud-object-storage.appdomain.cloud
#   jp-tok:    s3.jp-tok.cloud-object-storage.appdomain.cloud
COS_ENDPOINT=s3.us-south.cloud-object-storage.appdomain.cloud
COS_BUCKET=my-milvus-bucket

# HMAC credentials (NOT IAM tokens). Create via:
#   ibmcloud resource service-key-create milvus-hmac Writer \
#     --instance-name <cos-instance> --parameters '{"HMAC":true}'
COS_ACCESS_KEY=
COS_SECRET_KEY=

# ---- Storage class for WAL + etcd PVCs ----
# Common IBM Cloud OpenShift classes:
#   ibmc-vpc-block-general-purpose   (VPC clusters, default)
#   ibmc-vpc-block-10iops-tier       (higher IOPS)
#   ibmc-block-gold                  (Classic clusters)
STORAGE_CLASS=ibmc-vpc-block-general-purpose
WAL_SIZE=50Gi
ETCD_SIZE=10Gi

# ---- Resources for the standalone pod ----
CPU_REQUEST=1
CPU_LIMIT=4
MEM_REQUEST=4Gi
MEM_LIMIT=8Gi

# ---- External access via OpenShift Routes ----
# true  = script creates Routes (REST: edge TLS, gRPC: edge TLS + h2c)
# false = in-cluster only; use 'oc port-forward'
CREATE_ROUTES=true
