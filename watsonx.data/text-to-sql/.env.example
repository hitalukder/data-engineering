# ── IBM Cloud IAM ─────────────────────────────────────────────────
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here

# ── watsonx.data intelligence Text2SQL ────────────────────────────
# Project or catalog ID from your WDI instance
WXD_CONTAINER_ID=03ab6ef6-4bf9-40a8-84cb-755b427989ed
WXD_CONTAINER_TYPE=project

# Foundation model for SQL generation
WXD_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# WDI Text2SQL API base URL (do not change unless using a different region)
WXD_TEXT2SQL_BASE=https://api.dataplatform.cloud.ibm.com/semantic_automation/v1/text_to_sql

# ── IBM DB2 connection ────────────────────────────────────────────
DB2_HOSTNAME=your-db2-host.databases.appdomain.cloud
DB2_PORT=50001
DB2_DATABASE=BLUDB
DB2_SCHEMA=BGD20177
DB2_USERNAME=your_db2_user
DB2_PASSWORD=your_db2_password

# ── Service security ──────────────────────────────────────────────
# Shared secret — set this same value in watsonx Orchestrate tool credentials
APP_API_KEY=your_strong_random_secret_here

# ── OpenAPI base URL (for Orchestrate import) ─────────────────────
# Set this to your Code Engine application URL after deployment
SERVICE_BASE_URL=https://text2sql-service.your-code-engine-subdomain.us-south.codeengine.appdomain.cloud
